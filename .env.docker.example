# ==============================================================================
# HUSC RAG Chatbot - Docker Compose (.env)
# Copy: cp .env.docker.example .env
# Then edit the values below before: docker compose up -d --build
# ==============================================================================

# --- Required ---
SECRET_KEY=change-me-to-a-long-random-string
GEMINI_API_KEY=your-gemini-api-key

# --- SQL Server (shared by sqlserver + ui containers) ---
# Must meet SQL Server strong password policy (upper, lower, number, symbol, 8+ chars)
DB_PASSWORD=ChangeMe_Strong@Pass123
DB_USER=sa
DB_NAME=ChatbotDB

# --- Email (optional) ---
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Admin bootstrap (optional) ---
ADMIN_USER=
ADMIN_PASSWORD=

# --- RAG data paths (mounted into api container) ---
CSV_FILE=data/QA.csv
PDF_FILE=data/quyche.pdf

# Optional host port overrides if defaults are already in use:
# QDRANT_HOST_PORT=6335
# API_HOST_PORT=8010
# UI_HOST_PORT=5001
# SQLSERVER_HOST_PORT=14333
